# ══════════════════════════════════════════════════════════════════════════════
# Skills Dashboard — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is in .gitignore.

# ── AI Provider (REQUIRED) ────────────────────────────────────────────────────
#
# Choose ONE provider. Only AI_PROVIDER, AI_API_KEY, and AI_MODEL are required.
# AI_BASE_URL is only needed for the "local" provider.
#
# Supported providers:
#   anthropic   → Claude models (Anthropic API directly)
#   openai      → GPT models (OpenAI API)
#   gemini      → Gemini models (Google AI)
#   openrouter  → Any model via OpenRouter (openrouter.ai)
#   local       → Any OpenAI-compatible local model (Ollama, vLLM, LM Studio, etc.)
#
AI_PROVIDER=anthropic
AI_API_KEY=your-api-key-here
AI_MODEL=claude-sonnet-4-6
# AI_BASE_URL=http://localhost:11434/v1   # Only for "local" provider

# Provider examples:
#
# --- Anthropic (Claude) ---
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-6
#
# --- OpenAI ---
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o
#
# --- Google Gemini ---
# AI_PROVIDER=gemini
# AI_API_KEY=AIza...
# AI_MODEL=gemini-2.0-flash
#
# --- OpenRouter (access ANY model) ---
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-...
# AI_MODEL=anthropic/claude-sonnet-4-6
# Other OpenRouter model options:
#   google/gemini-2.0-flash
#   meta-llama/llama-3.3-70b-instruct
#   mistralai/mistral-small-3.1-24b-instruct
#
# --- Local (Ollama, vLLM, LM Studio, etc.) ---
# AI_PROVIDER=local
# AI_API_KEY=none
# AI_MODEL=llama3
# AI_BASE_URL=http://host.docker.internal:11434/v1
# Note: use host.docker.internal instead of localhost when running in Docker


# ── Firecrawl (OPTIONAL — enables author profile enrichment) ─────────────────
#
# Used to scrape author websites, X/Twitter profiles, etc. for the "Why Trust"
# author summaries. The dashboard works without this — author cards will just
# show basic info from the GitHub API.
#
# Option A: Self-hosted Firecrawl
# FIRECRAWL_API_URL=http://your-firecrawl-server:3002
# FIRECRAWL_API_KEY=dummy   # self-hosted doesn't need a real key
#
# Option B: Firecrawl Cloud (firecrawl.dev)
# FIRECRAWL_API_KEY=fc-...
#
FIRECRAWL_API_URL=
FIRECRAWL_API_KEY=


# ── Brave Search (OPTIONAL — enables real web search for author discovery) ────
#
# Used to find author websites, Skool communities, and social profiles via
# real web search. Without this, the dashboard falls back to parsing the
# author's GitHub profile README for links (less reliable).
#
# Free tier: 2,000 queries/month — plenty for author enrichment.
# Get a key at: https://api.search.brave.com/app/keys
#
BRAVE_SEARCH_API_KEY=


# ── GitHub Token (OPTIONAL — increases API rate limit) ───────────────────────
#
# Without a token, GitHub API allows 60 requests/hour per IP.
# With a token, it's 5,000 requests/hour. Recommended if you have many authors.
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
#
GITHUB_TOKEN=


# ── Scheduler ─────────────────────────────────────────────────────────────────
#
# Cron expression for the weekly automatic scan.
# Default: every Sunday at 02:00 AM (server time)
# See https://crontab.guru for help with cron syntax.
#
SCAN_SCHEDULE=0 2 * * 0


# ── Server Port (Docker / local dev) ─────────────────────────────────────────
PORT=3000
